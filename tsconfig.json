{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@metrev/domain-contracts": ["./packages/domain-contracts/src/index.ts"],
      "@metrev/domain-contracts/browser": [
        "./packages/domain-contracts/src/browser.ts"
      ],
      "@metrev/electrochem-models": [
        "./packages/electrochem-models/src/index.ts"
      ],
      "@metrev/rule-engine": ["./packages/rule-engine/src/index.ts"],
      "@metrev/audit": ["./packages/audit/src/index.ts"],
      "@metrev/telemetry": ["./packages/telemetry/src/index.ts"],
      "@metrev/telemetry/node": ["./packages/telemetry/src/node-sdk.ts"],
      "@metrev/llm-adapter": ["./packages/llm-adapter/src/index.ts"],
      "@metrev/research-intelligence": [
        "./packages/research-intelligence/src/index.ts"
      ],
      "@metrev/auth": ["./packages/auth/src/index.ts"],
      "@metrev/database": ["./packages/database/src/index.ts"],
      "@metrev/utils": ["./packages/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", ".next", "coverage"]
}
