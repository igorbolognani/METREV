generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum SupplierPreferenceType {
  CURRENT
  PREFERRED
  EXCLUDED
}

enum SupplierSourceState {
  RAW
  PARSED
  NORMALIZED
  REVIEWED
}

enum ExternalSourceType {
  OPENALEX
  CROSSREF
  EUROPE_PMC
  SUPPLIER_PROFILE
  MARKET_SNAPSHOT
  CURATED_MANIFEST
  MANUAL
}

enum ExternalAccessStatus {
  GOLD
  GREEN
  HYBRID
  BRONZE
  CLOSED
  UNKNOWN
}

enum IngestionRunStatus {
  STARTED
  COMPLETED
  FAILED
}

enum ExternalSourceState {
  RAW
  PARSED
  NORMALIZED
  REVIEWED
}

enum ExternalEvidenceReviewStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EvidenceClaimType {
  METRIC
  MATERIAL
  ARCHITECTURE
  CONDITION
  LIMITATION
  APPLICABILITY
  ECONOMIC
  SUPPLIER_CLAIM
  MARKET_SIGNAL
  OTHER
}

enum EvidenceExtractionMethod {
  MANUAL
  LLM
  REGEX
  ML
  IMPORT_RULE
}

enum OntologyMappingSource {
  AUTO
  ANALYST
  IMPORT_RULE
}

enum SupplierDocumentType {
  PROFILE
  DATASHEET
  SPECIFICATION
  CERTIFICATE
  MARKET_BRIEF
  CASE_STUDY
  PATENT_FILING
  REPORT
  OTHER
}

enum EvaluationEvidenceUsageType {
  ATTACHED_INPUT
  INPUT_SUPPORT
  DIAGNOSTIC_SUPPORT
  RECOMMENDATION_SUPPORT
  SUPPLIER_SUPPORT
  REPORT_CITATION
}

enum WorkspaceSnapshotType {
  DASHBOARD
  EVALUATION
  COMPARISON
  HISTORY
  EVIDENCE_REVIEW
  REPORT
  EXPORT_JSON
  EXPORT_CSV
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          Role      @default(VIEWER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CaseRecord {
  id                  String                    @id
  technologyFamily    String
  architectureFamily  String
  primaryObjective    String
  rawIntakeSnapshot   Json
  normalizedCase      Json
  defaultsUsed        String[]
  missingData         String[]
  assumptions         String[]
  typedEvidence       Json
  supplierContext     Json
  createdBy           String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  evaluations         EvaluationRecord[]
  evidenceRecords     EvidenceRecord[]
  supplierPreferences CaseSupplierPreference[]
  workspaceSnapshots  WorkspaceSnapshotRecord[]
  auditEvents         AuditEvent[]
}

model EvaluationRecord {
  id                     String                    @id
  caseId                 String
  idempotencyKey         String?                   @unique
  decisionOutput         Json
  auditRecord            Json
  narrative              String?
  narrativeMetadata      Json
  confidenceLevel        String
  provenanceSummary      Json
  scoringSummary         Json
  defaultsUsed           String[]
  missingData            String[]
  assumptions            String[]
  createdAt              DateTime                  @default(now())
  case                   CaseRecord                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  simulationArtifact     SimulationArtifactRecord?
  supplierShortlistItems SupplierShortlistItem[]
  sourceUsages           EvaluationSourceUsage[]
  claimUsages            EvaluationClaimUsage[]
  workspaceSnapshots     WorkspaceSnapshotRecord[]
  auditEvents            AuditEvent[]
}

model SimulationArtifactRecord {
  id                  String           @id @default(cuid())
  evaluationId        String           @unique
  status              String
  modelVersion        String
  inputSnapshot       Json
  derivedObservations Json
  series              Json
  assumptions         Json
  confidence          Json
  provenance          Json
  failureDetail       Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  evaluation          EvaluationRecord @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model Supplier {
  id              String                   @id @default(cuid())
  normalizedName  String                   @unique
  displayName     String
  category        String?
  region          String?
  metadata        Json
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  casePreferences CaseSupplierPreference[]
  shortlistItems  SupplierShortlistItem[]
  products        SupplierProduct[]
  documents       SupplierDocument[]
  evidenceRecords EvidenceRecord[]
}

model ExternalSourceRecord {
  id                   String                        @id @default(cuid())
  sourceType           ExternalSourceType
  sourceKey            String
  sourceUrl            String?
  title                String
  sourceCategory       String?
  doi                  String?
  publisher            String?
  journal              String?
  authors              Json?
  language             String?
  license              String?
  accessStatus         ExternalAccessStatus          @default(UNKNOWN)
  publishedAt          DateTime?
  asOf                 DateTime?
  pdfUrl               String?
  xmlUrl               String?
  hashDedup            String?
  ingestionRunId       String?
  abstractText         String?                       @db.Text
  rawPayload           Json
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  ingestionRun         IngestionRun?                 @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)
  catalogEvidenceItems ExternalEvidenceCatalogItem[]
  claims               EvidenceClaim[]
  supplierDocuments    SupplierDocument[]
  evaluationUsages     EvaluationSourceUsage[]

  @@unique([sourceType, sourceKey])
  @@index([sourceType, publishedAt])
  @@index([doi])
  @@index([ingestionRunId])
  @@index([hashDedup])
}

model ExternalEvidenceCatalogItem {
  id                 String                       @id @default(cuid())
  sourceRecordId     String
  evidenceType       String
  title              String
  summary            String                       @db.Text
  strengthLevel      String
  provenanceNote     String                       @db.Text
  reviewStatus       ExternalEvidenceReviewStatus @default(PENDING)
  sourceState        ExternalSourceState          @default(PARSED)
  claimCount         Int                          @default(0)
  applicabilityScope Json
  extractedClaims    Json
  tags               String[]
  payload            Json
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  sourceRecord       ExternalSourceRecord         @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  claims             EvidenceClaim[]

  @@unique([sourceRecordId, evidenceType, title])
  @@index([reviewStatus, evidenceType])
}

model IngestionRun {
  id             String                 @id @default(cuid())
  sourceType     ExternalSourceType
  triggerMode    String
  query          String?
  status         IngestionRunStatus
  recordsFetched Int                    @default(0)
  recordsStored  Int                    @default(0)
  checkpoint     Json?
  summary        Json
  failureDetail  Json?
  startedAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  sourceRecords  ExternalSourceRecord[]

  @@index([sourceType, startedAt])
}

model EvidenceClaim {
  id               String                       @id @default(cuid())
  sourceRecordId   String
  catalogItemId    String?
  claimType        EvidenceClaimType
  content          String                       @db.Text
  extractedValue   String?
  unit             String?
  confidence       Float
  extractionMethod EvidenceExtractionMethod
  extractorVersion String
  sourceSnippet    String                       @db.Text
  sourceLocator    String?
  pageNumber       Int?
  metadata         Json
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  sourceRecord     ExternalSourceRecord         @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  catalogItem      ExternalEvidenceCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  reviews          EvidenceClaimReview[]
  ontologyMappings EvidenceOntologyMapping[]
  evaluationUsages EvaluationClaimUsage[]

  @@index([sourceRecordId, claimType])
  @@index([catalogItemId, claimType])
  @@index([confidence, createdAt])
}

model EvidenceClaimReview {
  id          String                       @id @default(cuid())
  claimId     String
  status      ExternalEvidenceReviewStatus @default(PENDING)
  analystId   String?
  analystRole String?
  analystNote String?                      @db.Text
  reviewedAt  DateTime?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  claim       EvidenceClaim                @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, status])
  @@index([status, reviewedAt])
}

model EvidenceOntologyMapping {
  id                String                @id @default(cuid())
  claimId           String
  ontologyPath      String
  mappingConfidence Float
  mappedBy          OntologyMappingSource
  note              String?               @db.Text
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  claim             EvidenceClaim         @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@unique([claimId, ontologyPath])
  @@index([ontologyPath])
}

model SupplierProduct {
  id          String             @id @default(cuid())
  supplierId  String
  productKey  String
  displayName String
  category    String?
  trl         Int?
  metadata    Json
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  supplier    Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  documents   SupplierDocument[]

  @@unique([supplierId, productKey])
  @@index([supplierId, category])
}

model SupplierDocument {
  id             String               @id @default(cuid())
  supplierId     String
  sourceRecordId String
  productId      String?
  documentType   SupplierDocumentType
  note           String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  supplier       Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sourceRecord   ExternalSourceRecord @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  product        SupplierProduct?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([supplierId, sourceRecordId])
  @@index([productId, documentType])
}

model EvaluationSourceUsage {
  id             String                      @id @default(cuid())
  evaluationId   String
  sourceRecordId String
  usageType      EvaluationEvidenceUsageType
  note           String?                     @db.Text
  createdAt      DateTime                    @default(now())
  evaluation     EvaluationRecord            @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  sourceRecord   ExternalSourceRecord        @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, sourceRecordId, usageType])
  @@index([sourceRecordId, usageType])
}

model EvaluationClaimUsage {
  id           String                      @id @default(cuid())
  evaluationId String
  claimId      String
  usageType    EvaluationEvidenceUsageType
  note         String?                     @db.Text
  createdAt    DateTime                    @default(now())
  evaluation   EvaluationRecord            @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  claim        EvidenceClaim               @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, claimId, usageType])
  @@index([claimId, usageType])
}

model WorkspaceSnapshotRecord {
  id           String                @id @default(cuid())
  evaluationId String?
  caseId       String?
  snapshotType WorkspaceSnapshotType
  payload      Json
  createdAt    DateTime              @default(now())
  evaluation   EvaluationRecord?     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  case         CaseRecord?           @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, snapshotType])
  @@unique([caseId, snapshotType])
  @@index([snapshotType, createdAt])
}

model CaseSupplierPreference {
  id             String                 @id @default(cuid())
  caseId         String
  supplierId     String?
  supplierLabel  String
  preferenceType SupplierPreferenceType
  note           String?
  sourceState    SupplierSourceState
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  case           CaseRecord             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  supplier       Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@unique([caseId, preferenceType, supplierLabel])
  @@index([caseId, preferenceType])
}

model SupplierShortlistItem {
  id                 String              @id @default(cuid())
  evaluationId       String
  supplierId         String?
  candidateLabel     String
  category           String
  fitNote            String
  missingInformation Json
  reviewStatus       SupplierSourceState
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  evaluation         EvaluationRecord    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  supplier           Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([evaluationId, category])
}

model EvidenceRecord {
  id            String     @id
  caseId        String
  evidenceType  String
  title         String
  strengthLevel String
  supplierName  String?
  supplierId    String?
  payload       Json
  createdAt     DateTime   @default(now())
  case          CaseRecord @relation(fields: [caseId], references: [id], onDelete: Cascade)
  supplier      Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([caseId, supplierId])
}

model AuditEvent {
  id           String            @id
  caseId       String?
  evaluationId String?
  eventType    String
  actorRole    String
  actorId      String?
  payload      Json
  createdAt    DateTime          @default(now())
  case         CaseRecord?       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  evaluation   EvaluationRecord? @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([evaluationId, createdAt])
}
